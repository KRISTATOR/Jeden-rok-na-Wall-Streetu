rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "kristian.paca@montetrida.cz" ||
        request.auth.token.email == "paca.kristian@gmail.com" ||
        request.auth.token.email == "kristianai2011@gmail.com"
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rooms: Anyone authenticated can list/read/create. Only creator can update gameState.
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdAt is number;
      
      allow update: if isAuthenticated() && (
        // Creator can update anything (e.g. advance quarter)
        resource.data.createdBy == request.auth.uid ||
        // Others can only update prices via trade (this is a bit complex to enforce strictly without more functions, 
        // but we'll allow it for now as long as it's a valid trade update)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['gameState'])
      );

      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;

      // Portfolios within a room
      match /portfolios/{userId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || resource.data.createdBy == request.auth.uid);
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
      }
    }
  }
}
